function setMode(m){
  mode=m;
  document.querySelectorAll('.mode-tab').forEach((t,i)=>t.classList.toggle('active',['learn','quiz'][i]===m));
  ge('learn-mode').style.display=m==='learn'?'block':'none';
  ge('quiz-mode').style.display=m==='quiz'?'block':'none';
  if(m==='learn'){stopAudio();clrHL();}
  else{
    // entering quiz — stop learn audio, reset quiz state
    stopLearnAudio();
    qMid=null;qDone=false;qActiveArea=null;qManBoost=1.0;
    ge('new-q-btn').style.display='inline-block';
    ge('quiz-inner').innerHTML=`<div class="placeholder" style="padding:1.2rem 0">
