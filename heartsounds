<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>Cardiac Auscultation Simulator</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=DM+Sans:opsz,wght@9..40,400;9..40,500&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#f5f4f0;--surface:#fff;--surface2:#f0eeea;
  --border:#e2dfd8;--border2:#ccc9c0;
  --text:#1a1916;--text2:#6b6860;--text3:#b0ada6;
  --accent:#1a5fa8;--accent-bg:#eaf1fb;--accent-border:#b8d0f0;
  --green:#1a7a3a;--green-bg:#eaf6ee;--green-border:#a8dbb8;
  --red:#b83232;--red-bg:#fdf0f0;--red-border:#f0b8b8;
  --amber:#8a5e00;
  --r:10px;--rlg:14px;--sh:0 1px 3px rgba(0,0,0,.06),0 3px 12px rgba(0,0,0,.04);
}
html{font-size:14px}
body{background:var(--bg);color:var(--text);font-family:'DM Sans',sans-serif;min-height:100vh}
.shell{max-width:1000px;margin:0 auto;padding:.75rem .75rem 2rem}
header{text-align:center;margin-bottom:.9rem;padding-bottom:.9rem;border-bottom:1px solid var(--border)}
header h1{font-family:'DM Serif Display',serif;font-size:1.5rem;font-weight:400;letter-spacing:-.01em}
header p{font-size:.75rem;color:var(--text2);margin-top:2px}
.mode-tabs{display:flex;gap:5px;justify-content:center;margin-bottom:1rem}
.mode-tab{padding:6px 18px;border-radius:20px;border:1px solid var(--border2);background:transparent;color:var(--text2);font-family:'DM Sans',sans-serif;font-size:.75rem;font-weight:500;cursor:pointer;transition:all .15s}
.mode-tab.active{background:var(--accent);border-color:var(--accent);color:#fff}

/* top section */
.top-section{display:grid;grid-template-columns:100px 1fr 100px;gap:6px;align-items:center;margin-bottom:.75rem}
.man-col{display:flex;flex-direction:column;gap:4px}
.man-col-label{font-size:.62rem;font-weight:500;text-transform:uppercase;letter-spacing:.06em;color:var(--text3);text-align:center;margin-bottom:3px}
.mbtn{padding:5px 4px;border-radius:var(--r);border:1px solid var(--border);background:var(--surface);color:var(--text2);font-family:'DM Sans',sans-serif;font-size:.68rem;cursor:pointer;text-align:center;transition:all .15s;line-height:1.3;width:100%}
.mbtn:hover{border-color:var(--border2);color:var(--text);background:var(--surface2)}
.mbtn.active{background:var(--accent-bg);border-color:var(--accent-border);color:var(--accent)}
.mb{display:block;font-size:.6rem;font-weight:500;padding:1px 4px;border-radius:20px;margin-top:1px}
.up{background:var(--green-bg);color:var(--green)}.down{background:var(--red-bg);color:var(--red)}.neutral{background:var(--surface2);color:var(--text3)}
.body-wrap{display:flex;justify-content:center}
.body-svg{width:180px;display:block;overflow:visible}

/* auscultation zones */
.azone{cursor:pointer}
.azone .ring{fill-opacity:.12;stroke-width:1.5;transition:all .25s}
.azone:hover .ring{fill-opacity:.28;stroke-width:2.5}
.azone.active .ring{fill-opacity:.38;stroke-width:3}
.azone .pring{fill:none;stroke-width:1.5;opacity:0}
.azone.playing .pring{animation:pa 1.3s ease-out infinite}
@keyframes pa{0%{r:20;opacity:.7}100%{r:36;opacity:0}}
.azone.highlight .ring{fill-opacity:.5;stroke-width:3.5;animation:hl 1s ease-in-out infinite alternate}
@keyframes hl{0%{fill-opacity:.35}100%{fill-opacity:.65}}
.radarr{opacity:0;transition:opacity .4s;pointer-events:none}
.radarr.show{opacity:1}

/* legend */
.legend{display:flex;flex-wrap:wrap;gap:4px;justify-content:center;margin-top:4px}
.legitem{display:flex;align-items:center;gap:3px;font-size:.66rem;color:var(--text2)}
.legdot{width:6px;height:6px;border-radius:50%;flex-shrink:0}

/* cards */
.card{background:var(--surface);border:1px solid var(--border);border-radius:var(--rlg);padding:.9rem 1rem;box-shadow:var(--sh)}
.card+.card{margin-top:.6rem}
.clabel{font-size:.65rem;font-weight:500;text-transform:uppercase;letter-spacing:.07em;color:var(--text3);margin-bottom:7px}
.placeholder{padding:1.5rem .5rem;text-align:center;color:var(--text3);font-size:.78rem;line-height:1.6}
.placeholder svg{width:26px;height:26px;opacity:.25;display:block;margin:0 auto 8px;stroke:var(--text3)}
.area-header{display:flex;align-items:center;gap:7px;margin-bottom:9px}
.adot{width:9px;height:9px;border-radius:50%;flex-shrink:0}
.aname{font-size:.76rem;font-weight:500;color:var(--text2)}
.mpills{display:flex;flex-wrap:wrap;gap:4px}
.mpill{padding:4px 10px;border-radius:20px;border:1px solid var(--border2);background:transparent;color:var(--text2);font-family:'DM Sans',sans-serif;font-size:.73rem;cursor:pointer;transition:all .15s}
.mpill:hover{background:var(--surface2);color:var(--text)}
.mpill.active{background:var(--accent-bg);border-color:var(--accent-border);color:var(--accent)}
.waveform{width:100%;height:52px;display:block;border-radius:5px;margin:8px 0 5px}
.player-row{display:flex;align-items:center;gap:8px}
.pbtn{width:32px;height:32px;border-radius:50%;border:1px solid var(--border2);background:transparent;cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:all .15s}
.pbtn:hover{background:var(--surface2);border-color:var(--accent)}
.pbtn.playing{background:var(--accent);border-color:var(--accent)}
.pbtn svg{width:12px;height:12px;fill:var(--text)}
.pbtn.playing svg{fill:#fff}
.vtrack{flex:1;height:4px;background:var(--surface2);border-radius:2px;overflow:hidden;border:1px solid var(--border)}
.vfill{height:100%;border-radius:2px;background:var(--accent);transition:width .4s ease}
.vtext{font-size:.68rem;color:var(--text2);min-width:46px;text-align:right}
.anote{display:flex;align-items:center;gap:4px;font-size:.64rem;color:var(--text3);margin-top:4px}
.andot{width:5px;height:5px;border-radius:50%;background:var(--amber);flex-shrink:0}
.mname{font-family:'DM Serif Display',serif;font-size:1.1rem;font-weight:400;color:var(--text);margin-bottom:2px}
.msub{font-size:.74rem;color:var(--text2);line-height:1.5}
.mtags{display:flex;flex-wrap:wrap;gap:3px;margin-top:6px}
.tag{font-size:.64rem;padding:2px 7px;border-radius:20px;border:1px solid var(--border2);color:var(--text2);background:var(--surface2)}

/* walkthrough */
.wtnav{display:flex;border-radius:var(--r);overflow:hidden;border:1px solid var(--border);margin-bottom:.75rem}
.wtsb{flex:1;padding:7px 3px;font-size:.68rem;font-weight:500;font-family:'DM Sans',sans-serif;border:none;background:var(--surface2);color:var(--text3);cursor:pointer;border-right:1px solid var(--border);transition:all .15s;text-align:center}
.wtsb:last-child{border-right:none}
.wtsb.active{background:var(--accent);color:#fff}
.wtsb.done{background:var(--surface);color:var(--accent)}
.wtpanel{display:none}.wtpanel.active{display:block}
.wtbot{display:flex;justify-content:flex-end;margin-top:10px}
.wtnext{padding:6px 16px;border-radius:20px;border:1px solid var(--accent-border);background:var(--accent-bg);color:var(--accent);font-family:'DM Sans',sans-serif;font-size:.75rem;font-weight:500;cursor:pointer;transition:all .15s}
.wtnext:hover{background:var(--accent);color:#fff}
.bacard{border-radius:var(--r);padding:9px 12px;margin-bottom:8px;border:1px solid var(--accent-border);background:var(--accent-bg)}
.baname{font-size:.82rem;font-weight:500;margin-bottom:2px}
.badesc{font-size:.72rem;color:var(--text2)}
.radtext{font-size:.76rem;color:var(--text2);line-height:1.55}
.explbox{margin-top:5px;padding:7px 10px;border-radius:var(--r);background:var(--accent-bg);border:1px solid var(--accent-border);border-left:3px solid var(--accent);font-size:.74rem;color:var(--text2);line-height:1.5}
.manrow{display:flex;align-items:center;justify-content:space-between;padding:6px 10px;border-radius:var(--r);border:1px solid var(--border);background:var(--surface);color:var(--text2);font-family:'DM Sans',sans-serif;font-size:.76rem;cursor:pointer;text-align:left;transition:all .15s;width:100%;margin-bottom:4px}
.manrow:hover{background:var(--surface2);color:var(--text);border-color:var(--border2)}
.manrow.active{background:var(--accent-bg);border-color:var(--accent-border);color:var(--accent)}

/* quiz */
.quiz-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;flex-wrap:wrap;gap:6px}
.qscore{display:flex;gap:7px}
.spill{background:var(--surface2);border:1px solid var(--border);border-radius:var(--r);padding:4px 11px;font-size:.74rem;color:var(--text2)}
.spill strong{color:var(--text);margin-left:2px}
.ggrid{display:grid;grid-template-columns:1fr 1fr;gap:5px;margin-top:9px}
@media(max-width:400px){.ggrid{grid-template-columns:1fr}}
.gbtn{padding:8px 10px;border-radius:var(--r);border:1px solid var(--border);background:var(--surface);color:var(--text2);font-family:'DM Sans',sans-serif;font-size:.74rem;cursor:pointer;text-align:left;transition:all .15s}
.gbtn:hover:not(:disabled){background:var(--surface2);color:var(--text);border-color:var(--border2)}
.gbtn.correct{background:var(--green-bg);border-color:var(--green-border);color:var(--green)}
.gbtn.wrong{background:var(--red-bg);border-color:var(--red-border);color:var(--red)}
.gbtn:disabled{cursor:default;opacity:.75}
.rbox{margin-top:9px;padding:9px 12px;border-radius:var(--r);font-size:.78rem;line-height:1.5}
.rbox.correct{background:var(--green-bg);border:1px solid var(--green-border);color:var(--green)}
.rbox.wrong{background:var(--red-bg);border:1px solid var(--red-border);color:var(--red)}
.nbtn{margin-top:7px;padding:6px 14px;border-radius:20px;border:1px solid var(--border2);background:transparent;color:var(--text2);font-family:'DM Sans',sans-serif;font-size:.75rem;cursor:pointer;transition:all .15s}
.nbtn:hover{background:var(--surface2);color:var(--text)}

@media(max-width:600px){
  .top-section{grid-template-columns:80px 1fr 80px;gap:4px}
  .mbtn{font-size:.62rem;padding:4px 3px}
  .body-svg{width:150px}
  .q-area-grid{grid-template-columns:repeat(5,1fr)}
}
@media(max-width:400px){
  .top-section{grid-template-columns:72px 1fr 72px;gap:3px}
  .body-svg{width:130px}
  .q-area-grid{grid-template-columns:repeat(3,1fr) repeat(2,1fr)}
}
</style>
</head>
<body>
<div class="shell">
  <header>
    <h1>Cardiac Auscultation Simulator</h1>
    <p>Tap an area · explore murmurs · apply dynamic manoeuvres</p>
  </header>
  <div class="mode-tabs">
    <button class="mode-tab active" onclick="setMode('learn')">Learn</button>
    <button class="mode-tab" onclick="setMode('quiz')">Quiz</button>
  </div>

  <div class="top-section">
    <!-- LEFT manoeuvres -->
    <div class="man-col">
      <div class="man-col-label">Manoeuvres</div>
      <button class="mbtn" id="gbtn-inspire" onclick="triggerMan('inspire')">Inspiration<span class="mb up">↑ R-sided</span></button>
      <button class="mbtn" id="gbtn-expire"  onclick="triggerMan('expire')">Expiration<span class="mb up">↑ L-sided</span></button>
      <button class="mbtn" id="gbtn-squat"   onclick="triggerMan('squat')">Squatting<span class="mb up">↑ preload</span></button>
      <button class="mbtn" id="gbtn-stand"   onclick="triggerMan('stand')">Standing<span class="mb up">↑ HOCM</span></button>
    </div>

    <!-- BODY -->
    <div class="body-wrap">
      <svg class="body-svg" id="body-svg" viewBox="0 0 160 480" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <marker id="ab" markerWidth="5" markerHeight="5" refX="2.5" refY="2.5" orient="auto"><path d="M0,0 L5,2.5 L0,5 Z" fill="#1a5fa8"/></marker>
          <marker id="ap" markerWidth="5" markerHeight="5" refX="2.5" refY="2.5" orient="auto"><path d="M0,0 L5,2.5 L0,5 Z" fill="#a8326e"/></marker>
        </defs>
        <g id="g-squat" style="transform-origin:80px 420px;transition:transform .6s ease-in-out">
          <g id="g-lean" style="transform-origin:80px 200px;transition:transform .6s ease-in-out">
            <!-- head -->
            <circle cx="80" cy="28" r="22" fill="#fdf8f3" stroke="#ddd9d0" stroke-width="1.2"/>
            <ellipse cx="57" cy="28" rx="4" ry="6" fill="#fdf8f3" stroke="#ddd9d0" stroke-width="1"/>
            <ellipse cx="103" cy="28" rx="4" ry="6" fill="#fdf8f3" stroke="#ddd9d0" stroke-width="1"/>
            <g id="eyes-normal">
              <ellipse cx="72" cy="25" rx="4" ry="3" fill="#fff" stroke="#c8c4bc" stroke-width=".8"/>
              <circle cx="72" cy="26" r="2" fill="#4a3828"/>
              <ellipse cx="88" cy="25" rx="4" ry="3" fill="#fff" stroke="#c8c4bc" stroke-width=".8"/>
              <circle cx="88" cy="26" r="2" fill="#4a3828"/>
            </g>
            <path d="M72,35 Q80,38 88,35" fill="none" stroke="#c8c4bc" stroke-width="1" stroke-linecap="round"/>
            <!-- valsalva face -->
            <g id="g-vf" style="opacity:0;transition:opacity .4s">
              <ellipse cx="63" cy="30" rx="8" ry="6" fill="#f0a0a0" opacity=".4"/>
              <ellipse cx="97" cy="30" rx="8" ry="6" fill="#f0a0a0" opacity=".4"/>
              <ellipse cx="80" cy="36" rx="5" ry="3" fill="#c87070" stroke="#a85050" stroke-width=".8"/>
              <ellipse cx="80" cy="36" rx="2.5" ry="1.5" fill="#a85050"/>
              <path d="M58,18 Q55,14 58,10" fill="none" stroke="#c8c4bc" stroke-width=".8"/>
              <path d="M102,18 Q105,14 102,10" fill="none" stroke="#c8c4bc" stroke-width=".8"/>
              <path d="M68,24 Q72,22 76,24" fill="none" stroke="#4a3828" stroke-width="1.2" stroke-linecap="round"/>
              <path d="M84,24 Q88,22 92,24" fill="none" stroke="#4a3828" stroke-width="1.2" stroke-linecap="round"/>
            </g>
            <!-- neck -->
            <rect x="72" y="49" width="16" height="14" rx="5" fill="#fdf8f3" stroke="#ddd9d0" stroke-width="1"/>
            <!-- breath group -->
            <g id="g-breath" style="transform-origin:80px 130px;transition:transform .7s ease-in-out">
              <path d="M42,64 Q28,76 24,104 L18,190 Q16,220 26,242 Q48,288 80,292 Q112,288 134,242 Q144,220 142,190 L136,104 Q132,76 118,64 Q100,52 80,52 Q60,52 42,64 Z" fill="#fafaf8" stroke="#ddd9d0" stroke-width="1.2"/>
              <path d="M56,68 Q68,62 80,64 Q92,62 104,68" fill="none" stroke="#c8c4bc" stroke-width="1.2"/>
              <line x1="80" y1="68" x2="80" y2="240" stroke="#e0ddd6" stroke-width="1" stroke-dasharray="3,3"/>
              <path d="M66,90 Q56,100 53,114" fill="none" stroke="#e8e4dc" stroke-width="1"/>
              <path d="M94,90 Q104,100 107,114" fill="none" stroke="#e8e4dc" stroke-width="1"/>
              <path d="M58,114 Q46,128 44,146" fill="none" stroke="#e8e4dc" stroke-width="1"/>
              <path d="M102,114 Q114,128 116,146" fill="none" stroke="#e8e4dc" stroke-width="1"/>
              <path d="M44,146 Q36,162 36,180" fill="none" stroke="#e8e4dc" stroke-width="1"/>
              <path d="M116,146 Q124,162 124,180" fill="none" stroke="#e8e4dc" stroke-width="1"/>
              <text x="18" y="84" font-size="7" fill="#c0bdb5" font-family="DM Sans,sans-serif">pt R</text>
              <text x="120" y="84" font-size="7" fill="#c0bdb5" font-family="DM Sans,sans-serif">pt L</text>

              <!-- AORTIC: patient R → viewer LEFT -->
              <g class="azone" id="zone-aortic" onclick="handleZoneClick('aortic')">
                <circle class="pring" cx="62" cy="96" r="18" stroke="#1a5fa8"/>
                <circle class="ring" cx="62" cy="96" r="18" fill="#1a5fa8" stroke="#1a5fa8"/>
                <text x="62" y="93" text-anchor="middle" font-size="7" font-weight="500" fill="#1a5fa8" font-family="DM Sans,sans-serif">Aortic</text>
                <text x="62" y="101" text-anchor="middle" font-size="6.5" fill="#5a8fc8" font-family="DM Sans,sans-serif">R 2nd</text>
              </g>
              <!-- PULMONARY: patient L → viewer RIGHT -->
              <g class="azone" id="zone-pulmonary" onclick="handleZoneClick('pulmonary')">
                <circle class="pring" cx="98" cy="96" r="18" stroke="#1a7a3a"/>
                <circle class="ring" cx="98" cy="96" r="18" fill="#1a7a3a" stroke="#1a7a3a"/>
                <text x="98" y="93" text-anchor="middle" font-size="7" font-weight="500" fill="#1a7a3a" font-family="DM Sans,sans-serif">Pulm.</text>
                <text x="98" y="101" text-anchor="middle" font-size="6.5" fill="#4aa870" font-family="DM Sans,sans-serif">L 2nd</text>
              </g>
              <!-- ERB'S -->
              <g class="azone" id="zone-erbs" onclick="handleZoneClick('erbs')">
                <circle class="pring" cx="80" cy="128" r="13" stroke="#6840b8"/>
                <circle class="ring" cx="80" cy="128" r="13" fill="#6840b8" stroke="#6840b8"/>
                <text x="80" y="125" text-anchor="middle" font-size="6.5" font-weight="500" fill="#6840b8" font-family="DM Sans,sans-serif">Erb's</text>
                <text x="80" y="133" text-anchor="middle" font-size="6" fill="#9070d8" font-family="DM Sans,sans-serif">3rd</text>
              </g>
              <!-- TRICUSPID -->
              <g class="azone" id="zone-tricuspid" onclick="handleZoneClick('tricuspid')">
                <circle class="pring" cx="92" cy="158" r="18" stroke="#8a5e00"/>
                <circle class="ring" cx="92" cy="158" r="18" fill="#8a5e00" stroke="#8a5e00"/>
                <text x="92" y="155" text-anchor="middle" font-size="7" font-weight="500" fill="#8a5e00" font-family="DM Sans,sans-serif">Trisp.</text>
                <text x="92" y="163" text-anchor="middle" font-size="6.5" fill="#b88a30" font-family="DM Sans,sans-serif">LLSB</text>
              </g>
              <!-- MITRAL -->
              <g class="azone" id="zone-mitral" onclick="handleZoneClick('mitral')">
                <circle class="pring" cx="104" cy="196" r="18" stroke="#a8326e"/>
                <circle class="ring" cx="104" cy="196" r="18" fill="#a8326e" stroke="#a8326e"/>
                <text x="104" y="193" text-anchor="middle" font-size="7" font-weight="500" fill="#a8326e" font-family="DM Sans,sans-serif">Mitral</text>
                <text x="104" y="201" text-anchor="middle" font-size="6.5" fill="#c86898" font-family="DM Sans,sans-serif">Apex</text>
              </g>

              <!-- radiation arrows -->
              <g id="rad-carotids" class="radarr">
                <line x1="69" y1="80" x2="69" y2="46" stroke="#1a5fa8" stroke-width="1.2" stroke-dasharray="2.5,2.5" marker-end="url(#ab)"/>
                <text x="52" y="44" font-size="6.5" fill="#1a5fa8" font-family="DM Sans,sans-serif">carotids</text>
              </g>
              <g id="rad-axilla" class="radarr">
                <line x1="118" y1="202" x2="144" y2="218" stroke="#a8326e" stroke-width="1.2" stroke-dasharray="2.5,2.5" marker-end="url(#ap)"/>
                <text x="138" y="228" font-size="6.5" fill="#a8326e" font-family="DM Sans,sans-serif">axilla</text>
              </g>
            </g>

            <!-- arms -->
            <path d="M24,108 Q10,130 12,165 Q13,180 18,190" fill="none" stroke="#fdf8f3" stroke-width="14" stroke-linecap="round"/>
            <path d="M24,108 Q10,130 12,165 Q13,180 18,190" fill="none" stroke="#ddd9d0" stroke-width="1" stroke-linecap="round"/>
            <ellipse cx="16" cy="194" rx="10" ry="7" fill="#fdf8f3" stroke="#ddd9d0" stroke-width="1"/>
            <path d="M136,108 Q150,130 148,165 Q147,180 142,190" fill="none" stroke="#fdf8f3" stroke-width="14" stroke-linecap="round"/>
            <path d="M136,108 Q150,130 148,165 Q147,180 142,190" fill="none" stroke="#ddd9d0" stroke-width="1" stroke-linecap="round"/>
            <ellipse cx="144" cy="194" rx="10" ry="7" fill="#fdf8f3" stroke="#ddd9d0" stroke-width="1"/>

            <!-- handgrip overlay -->
            <g id="g-hg" style="opacity:0;transition:opacity .4s">
              <ellipse cx="62" cy="250" rx="14" ry="9" fill="#fdf8f3" stroke="#ddd9d0" stroke-width="1.2"/>
              <line x1="52" y1="245" x2="52" y2="258" stroke="#ddd9d0" stroke-width=".8"/>
              <line x1="57" y1="243" x2="57" y2="259" stroke="#ddd9d0" stroke-width=".8"/>
              <line x1="62" y1="242" x2="62" y2="259" stroke="#ddd9d0" stroke-width=".8"/>
              <line x1="67" y1="243" x2="67" y2="259" stroke="#ddd9d0" stroke-width=".8"/>
              <ellipse cx="98" cy="250" rx="14" ry="9" fill="#fdf8f3" stroke="#ddd9d0" stroke-width="1.2"/>
              <line x1="88" y1="245" x2="88" y2="258" stroke="#ddd9d0" stroke-width=".8"/>
              <line x1="93" y1="243" x2="93" y2="259" stroke="#ddd9d0" stroke-width=".8"/>
