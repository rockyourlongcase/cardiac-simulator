function selectLearnArea(id){
  activeArea=id; activeMurmur=null;
  stopLearnAudio(); clrHL();
  document.querySelectorAll('.azone').forEach(z=>z.classList.remove('active'));
  ge('zone-'+id).classList.add('active');
  const a=AREAS[id];
  ge('learn-ph').style.display='none';
  ge('learn-content').style.display='block';
  ge('l-adot').style.background=a.color;
  ge('l-aname').textContent=a.name+' — '+a.loc;
  ge('l-pills').innerHTML=a.murmurs.map(mid=>`<button class="mpill" id="pill-${mid}" onclick="selectMurmur('${mid}')">${M[mid].name}</button>`).join('');
  ge('l-wt').style.display='none';
  if(a.murmurs.length) selectMurmur(a.murmurs[0]);
}

function selectMurmur(mid){
  activeMurmur=mid; learnStep=0;
  stopLearnAudio(); clrHL();
  document.querySelectorAll('.mpill').forEach(p=>p.classList.remove('active'));
  const p=ge('pill-'+mid); if(p) p.classList.add('active');
  const m=M[mid];
  ge('l-mname').textContent=m.name;
  ge('l-msub').textContent=m.short;
  ge('l-mtags').innerHTML=m.tags.map(t=>`<span class="tag">${t}</span>`).join('');
  ge('l-wt').style.display='block';
  drawWave('lcanvas',m.wave,1); setVol('lvf','lvt',1);
  const col=AREAS[m.ba]?AREAS[m.ba].color:'#1a5fa8';
  const bc=ge('l-bacard');
  bc.style.cssText=`border-radius:var(--r);padding:9px 12px;margin-bottom:8px;border:1px solid ${col}40;background:${col}10`;
  ge('l-baname').style.color=col;
  ge('l-baname').textContent=m.bn;
  ge('l-badesc').textContent=m.bd;
  ge('l-radtxt').textContent=m.rad;
  renderMans('l-manlist','l-expl',m.mans,'l');
  goStep(0);
}

function goStep(n){
  learnStep=n;
  document.querySelectorAll('.wtpanel').forEach((p,i)=>p.classList.toggle('active',i===n));
  document.querySelectorAll('.wtsb').forEach((b,i)=>{b.classList.remove('active','done');if(i===n)b.classList.add('active');else if(i<n)b.classList.add('done');});
  clrHL();
  if(n===1&&activeMurmur){
    const m=M[activeMurmur];
    ge('zone-'+m.ba)?.classList.add('highlight');
    if(m.rid) ge(m.rid)?.classList.add('show');
  }
  if(n===2){ge('l-expl').innerHTML='';document.querySelectorAll('[id^="l-man-"]').forEach(b=>b.classList.remove('active'));}
}

function toggleLearnPlay(){
  if(playing&&pctx==='l'){stopLearnAudio();return;}
  if(!activeMurmur) return;
  const m=M[activeMurmur];
  playAudio(m.wave,m.wave.v,activeMurmur,'l');
}

function stopLearnAudio(){
  if(pctx==='l') stopAudio();
}

// ════════════════════════════════════════
//  QUIZ MODE
// ════════════════════════════════════════
function newQuiz(){
  // pick a random murmur from ALL murmurs
  const allMids=Object.keys(M);
  qMid=allMids[Math.floor(Math.random()*allMids.length)];
  qDone=false; qActiveArea=null; qManBoost=1.0;
  clrHL();
  document.querySelectorAll('.azone').forEach(z=>z.classList.remove('active','playing'));
  stopAudio();
  ge('new-q-btn').style.display='none';

  // render quiz inner
  ge('quiz-inner').innerHTML=`
    <div style="font-size:.72rem;color:var(--text2);margin-bottom:6px">Tap areas on the chest to listen — use the manoeuvre buttons for clues</div>
    <canvas class="waveform" id="qcanvas"></canvas>
    <div class="anote" style="margin-bottom:10px"><span class="andot"></span>Synthesised audio — replace with real files (see README)</div>
    <div class="clabel">What murmur is this?</div>
    <div class="ggrid" id="ggrid"></div>
    <div id="qres"></div>`;

  // build area grid
  const vols=AREA_VOLS[qMid];
  ge('q-area-grid').innerHTML=AREA_KEYS.map(k=>`
    <button class="q-area-btn" id="qab-${k}" onclick="selectQuizArea('${k}')" style="border-color:${AREA_COLORS[k]}40">
      <span style="color:${AREA_COLORS[k]};font-weight:500">${AREA_LABELS[k]}</span>
      <span class="vol-pip" id="qpip-${k}" style="width:0%"></span>
    </button>`).join('');

  // build answer grid
  const dist=Object.entries(M).filter(([k])=>k!==qMid).sort(()=>Math.random()-.5).slice(0,3);
  ge('ggrid').innerHTML=[[qMid,M[qMid]],...dist].sort(()=>Math.random()-.5).map(([k,m])=>`<button class="gbtn" onclick="makeGuess('${k}','${qMid}')">${m.name}</button>`).join('');



  // auto-select first area (best area) to start audio
  // but don't reveal it — pick a random area to start on
  const startArea=AREA_KEYS[Math.floor(Math.random()*AREA_KEYS.length)];
  selectQuizArea(startArea);
}

function selectQuizArea(areaId){
  if(mode!=='quiz'||!qMid) return;
  qActiveArea=areaId;

  // highlight active zone on body
  document.querySelectorAll('.azone').forEach(z=>z.classList.remove('active'));
  ge('zone-'+areaId)?.classList.add('active');

  // calculate volume for this area
  const baseVol=getQuizVol(areaId);
  const finalVol=Math.min(baseVol*qManBoost,1.0);

  // update waveform amplitude
  drawWave('qcanvas',M[qMid].wave,finalVol);

  // update audio — seamless gain change if already playing, otherwise start
  if(playing&&pctx==='q'){
    setGain(finalVol);
    document.querySelectorAll('.azone').forEach(z=>z.classList.remove('playing'));
    ge('zone-'+areaId)?.classList.add('playing');
  } else {
    playAudio(M[qMid].wave,finalVol,qMid,'q');
  }
}

function getQuizVol(areaId){
  const vols=AREA_VOLS[qMid];
  return vols?vols[areaId]||0.1:0.5;
}



function makeGuess(gid,cid){
  if(qDone) return;
  qDone=true; qT++;
  const ok=gid===cid; if(ok) qC++;
  ge('qsc').textContent=qC; ge('qst').textContent=qT;
  document.querySelectorAll('.gbtn').forEach(b=>{
    const bid=b.getAttribute('onclick').match(/'([^']+)'/)[1];
    if(bid===cid) b.classList.add('correct');
    else if(bid===gid&&!ok) b.classList.add('wrong');
    b.disabled=true;
  });
  ge('qres').innerHTML=`<div class="rbox ${ok?'correct':'wrong'}">${ok?'Correct!':'Incorrect.'} This is <strong>${M[cid].name}</strong>.<br><span style="font-size:.72rem;opacity:.85">${M[cid].short}</span></div>`;
  ge('new-q-btn').style.display='inline-block';
}

// ════════════════════════════════════════
//  MANOEUVRE PANELS
// ════════════════════════════════════════
function renderMans(lid,eid,mans,ctx){
  const el=ge(lid); el._mans=mans;
  el.innerHTML=mans.map((m,i)=>{
    const bc=m.e==='up'?'up':m.e==='down'?'down':'neutral';
    const bt=m.e==='up'?'↑ louder':m.e==='down'?'↓ softer':'→ no change';
    return `<button class="manrow" id="${ctx}-man-${i}" onclick="toggleMan('${ctx}',${i})">${m.l}<span class="mb ${bc}" style="margin-left:8px">${bt}</span></button>`;
  }).join('');
  ge(eid).innerHTML='';
}

function toggleMan(ctx,i){
  const el=ge(ctx+'-manlist');
  const eid='l-expl';
  const man=el._mans[i];
  const was=ge(ctx+'-man-'+i).classList.contains('active');
  document.querySelectorAll(`[id^="${ctx}-man-"]`).forEach(b=>b.classList.remove('active'));
  if(was){
    ge(eid).innerHTML='';
    rstVol('l');
    return;
  }
  ge(ctx+'-man-'+i).classList.add('active');
  ge(eid).innerHTML=`<div class="explbox">${man.d}</div>`;
  const v=man.e==='up'?1.0:man.e==='down'?0.22:0.65;
  setVol('lvf','lvt',v);
  drawWave('lcanvas',M[activeMurmur].wave,v);
  if(playing&&pctx==='l') setGain(v);
}

function rstVol(ctx){
  if(ctx==='l'){setVol('lvf','lvt',1);if(activeMurmur)drawWave('lcanvas',M[activeMurmur].wave,1);}
}

function setVol(fi,ti,v){
  const fe=ge(fi); if(fe) fe.style.width=Math.round(Math.min(v,1)*100)+'%';
  const te=ge(ti); if(te) te.textContent=v>=.9?'Loud':v>=.6?'Clear':v>=.35?'Faint':'Quiet';
}

// ════════════════════════════════════════
//  GLOBAL MANOEUVRE ANIMATIONS
// ════════════════════════════════════════
function animBreath(sx,sy){ge('g-breath').style.transform=`scale(${sx},${sy})`}
function animLean(s){ge('g-lean').style.transform=s?`skewX(${s}deg)`:'';}
function animLLD(d){ge('g-lean').style.transform=d?`rotate(${d}deg)`:'';}
function animSquat(b){
  const td=b*38,sd=b*-70;
  ge('g-leg-left').style.transform=`rotate(${td}deg)`;
  ge('g-leg-right').style.transform=`rotate(${-td}deg)`;
  ge('g-shin-left').style.transform=`rotate(${sd}deg)`;
  ge('g-shin-right').style.transform=`rotate(${sd}deg)`;
}
function animStand(){['g-leg-left','g-leg-right','g-shin-left','g-shin-right'].forEach(id=>ge(id).style.transform='');}
function showHG(on){ge('g-hg').style.opacity=on?1:0;}
function showVF(on){ge('g-vf').style.opacity=on?1:0;}
function showBadge(t){ge('badge-bg').setAttribute('opacity','1');ge('badge-txt').textContent=t;ge('badge-txt').setAttribute('opacity','1');}
function hideBadge(){ge('badge-bg').setAttribute('opacity','0');ge('badge-txt').setAttribute('opacity','0');}
function resetAnims(){animBreath(1,1);ge('g-lean').style.transform='';animStand();showHG(false);showVF(false);hideBadge();}

const MDEFS={
  inspire: {label:'Inspiring...',  start(){animBreath(1.06,1.04)}, end(){animBreath(1,1)}},
  expire:  {label:'Expiring...',   start(){animBreath(.93,.97)},   end(){animBreath(1,1)}},
  squat:   {label:'Squatting...',  start(){animSquat(1)},          end(){animSquat(0)}},
  stand:   {label:'Standing...',   start(){animStand()},           end(){}},
  valsalva:{label:'Valsalva...',   start(){animBreath(.90,.95);showVF(true)}, end(){animBreath(1,1);showVF(false)}},
  lean:    {label:'Leaning fwd...', start(){animLean(-8)},          end(){animLean(0)}},
  handgrip:{label:'Handgrip...',   start(){showHG(true)},          end(){showHG(false)}},
  lld:     {label:'Left lat. dec.',start(){animLLD(12)},           end(){animLLD(0)}},
};

function triggerMan(key){
  const def=MDEFS[key]; if(!def) return;
  if(manTmo) clearTimeout(manTmo);
  resetAnims();
  document.querySelectorAll('[id^="gbtn-"]').forEach(b=>b.classList.remove('active'));
  ge('gbtn-'+key)?.classList.add('active');
  showBadge(def.label); def.start();

  // apply effect to audio
  if(mode==='learn'&&playing&&pctx==='l'&&activeMurmur){
    const eff=getEff(key,activeMurmur);
    const v=eff==='up'?1.0:eff==='down'?0.22:0.65;
    setGain(v);
    setTimeout(()=>{if(playing&&pctx==='l') setGain(M[activeMurmur].wave.v);},2400);
  }
  if(mode==='quiz'&&qMid&&qActiveArea){
    const eff=getEff(key,qMid);
    qManBoost=eff==='up'?1.4:eff==='down'?0.3:1.0;
    selectQuizArea(qActiveArea);
    setTimeout(()=>{qManBoost=1.0;if(qActiveArea) selectQuizArea(qActiveArea);},2400);
  }

  manTmo=setTimeout(()=>{def.end();hideBadge();document.querySelectorAll('[id^="gbtn-"]').forEach(b=>b.classList.remove('active'));},2400);
}

function getEff(key,mid){
  const lmap={inspire:'nspir',expire:'xpir',squat:'quat',valsalva:'alsalva',lean:'ean',handgrip:'andgrip',lld:'eft lat',stand:'tand'};
  const lbl=lmap[key]||'';
  const m=M[mid]; if(!m) return 'neutral';
  const match=m.mans.find(mn=>mn.l.toLowerCase().includes(lbl.toLowerCase()));
  return match?match.e:'neutral';
}

// ════════════════════════════════════════
//  WAVEFORM
// ════════════════════════════════════════
function drawWave(cid,wave,vol){
  const c=ge(cid); if(!c) return;
  const dpr=window.devicePixelRatio||1,w=c.offsetWidth||260,h=52;
  c.width=w*dpr; c.height=h*dpr; c.style.width=w+'px'; c.style.height=h+'px';
  const cx=c.getContext('2d'); cx.scale(dpr,dpr); cx.clearRect(0,0,w,h);
  cx.strokeStyle='#1a5fa8'; cx.lineWidth=1.5;
  const amp=(h/2-4)*Math.min(vol,1), mid=h/2;
  cx.beginPath();
  for(let x=0;x<w;x++){
    const t=x/w,cy=t%0.8; let y=mid;
    const tp=wave.t;
    if(tp==='ejs'){if(cy<.38){const p=cy/.38;y=mid-amp*Math.sin(Math.PI*p)*(.7+.3*Math.sin(wave.f/60*Math.PI*p));}}
    else if(tp==='pan'){if(cy<.44){const p=cy/.44;y=mid-amp*.85*Math.sin(wave.f/80*Math.PI*p)*Math.sin(1.2*Math.PI*p);}}
    else if(tp==='edi'){if(cy>.42&&cy<.78){const p=(cy-.42)/.36;y=mid-amp*(1-p)*.9*Math.sin(wave.f/70*Math.PI*p);}}
    else if(tp==='mdi'){if(cy>.5&&cy<.76){const p=(cy-.5)/.26;y=mid-amp*.65*Math.sin(Math.PI*p)*Math.sin(wave.f/90*Math.PI*p);}}
    else if(tp==='fxs'){if(cy<.04||(cy>.38&&cy<.44)||(cy>.46&&cy<.52)){y=mid-amp*.55*Math.sin(wave.f/60*Math.PI*cy);}}
    else if(tp==='mvp'){if(cy>.2&&cy<.44){const p=(cy-.2)/.24;y=mid-amp*.8*Math.sin(wave.f/70*Math.PI*p)*p;}}
    else if(tp==='cont'){y=mid-amp*.55*Math.sin(wave.f/60*Math.PI*t)*(.6+.4*Math.sin(Math.PI*cy/.8));}
    x===0?cx.moveTo(x,y):cx.lineTo(x,y);
  }
  cx.stroke();
}

// ════════════════════════════════════════
//  AUDIO ENGINE
// ════════════════════════════════════════
function ge(id){return document.getElementById(id)}
function initACtx(){
  if(!actx) actx=new(window.AudioContext||window.webkitAudioContext)();
  if(actx.state==='suspended') actx.resume();
}
function stopAudio(){
  anodes.forEach(n=>{try{n.stop?n.stop():n.pause&&(n.pause(),n.currentTime=0);}catch(e){}});
  anodes=[]; gainNode=null; playing=false;
  updatePlayBtn('l',false); updatePlayBtn('q',false);
  document.querySelectorAll('.azone').forEach(z=>z.classList.remove('playing'));
}
function playAudio(wave,vol,mid,ctx){
  stopAudio();
  initACtx();
  pctx=ctx;
  const file=AF[mid];
  if(file){
    const a=new Audio(file);
    a.loop=true; a.volume=Math.min(vol,1);
    a.play().catch(()=>{});
    anodes.push(a);
    // store ref so we can update volume
    gainNode={_audio:a,gain:{value:vol}};
  } else {
    const gn=actx.createGain(); gn.gain.value=vol*.05; gn.connect(actx.destination);
    gainNode=gn;
    freqs(wave).forEach(f=>{
      const o=actx.createOscillator(); o.type='sine'; o.frequency.value=f;
      const mg=actx.createGain(); mg.gain.value=.3;
      if(wave.t==='ejs'||wave.t==='pan'){
        const lfo=actx.createOscillator(); lfo.frequency.value=1.4; lfo.connect(mg.gain); lfo.start(); anodes.push(lfo);
      }
      o.connect(mg); mg.connect(gn); o.start(); anodes.push(o);
    });
  }
  playing=true;
  updatePlayBtn(ctx,true);
  if(ctx==='q'&&ge('zone-'+qActiveArea)) ge('zone-'+qActiveArea).classList.add('playing');
}

function setGain(vol){
  if(!gainNode) return;
  if(gainNode._audio){
    gainNode._audio.volume=Math.min(vol,1);
  } else {
    gainNode.gain.setTargetAtTime(vol*.05,actx.currentTime,.05);
  }
}

function freqs(w){
  const b=w.f;
  if(w.t==='mdi') return[b,b*1.5,b*2];
  if(w.t==='edi') return[b,b*1.3,b*2.1];
  if(w.t==='fxs') return[b*2,b*2.6];
  if(w.t==='cont') return[b,b*1.4,b*2,b*3.2];
  return[b,b*1.4,b*2.2,b*3.1];
}

function updatePlayBtn(ctx,on){
  const b=ge(ctx+'pbtn'), i=ge(ctx+'pico');
  if(b) b.classList.toggle('playing',on);
  if(i) i.innerHTML=on?'<rect x="4" y="2" width="3" height="12"/><rect x="9" y="2" width="3" height="12"/>':'<polygon points="4,2 14,8 4,14"/>';
}
function updateQPlayBtn(on){updatePlayBtn('q',on);}

function clrHL(){
  document.querySelectorAll('.azone').forEach(z=>z.classList.remove('highlight'));
  document.querySelectorAll('.radarr').forEach(a=>a.classList.remove('show'));
}

window.addEventListener('resize',()=>{
  if(activeMurmur) drawWave('lcanvas',M[activeMurmur].wave,1);
  if(qMid&&qActiveArea) drawWave('qcanvas',M[qMid].wave,getQuizVol(qActiveArea)*qManBoost);
});
</script>
